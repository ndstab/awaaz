# Secret key for Django, set this to a long random string in your .env file
SECRET_KEY=change-me-in-production
# Django debug mode, set to False in production
DEBUG=True
# Comma separated list of allowed hostnames for this instance
ALLOWED_HOSTS=localhost,127.0.0.1
# PostgreSQL / PostGIS database name
POSTGRES_DB=awaaz
# PostgreSQL / PostGIS database user
POSTGRES_USER=awaaz
# PostgreSQL / PostGIS database password
POSTGRES_PASSWORD=awaaz
# PostgreSQL / PostGIS database host (the docker-compose service name by default)
POSTGRES_HOST=db
# PostgreSQL / PostGIS database port
POSTGRES_PORT=5432
# Celery broker URL, default points at the Redis service in docker-compose
CELERY_BROKER_URL=redis://redis:6379/0
# Celery result backend URL, default points at the Redis service in docker-compose
CELERY_RESULT_BACKEND=redis://redis:6379/1

